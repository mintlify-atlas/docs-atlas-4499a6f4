  "keyFeatures": [
    "YAML-based configuration for application launcher entries",
    "Dual UI modes: fuzzel integration and native iced-based GUI",
    "Built-in calculator with mathematical functions",
    "Currency converter with real-time exchange rates",
    "Interactive file browser with fuzzy filtering",
    "Script filters compatible with Alfred JSON format",
    "Web search shortcuts with custom keywords",
    "Text snippets system with multiple sources",
    "Conditional entry display based on environment",
    "Icon caching and automatic discovery",
    "Path expansion for tilde and environment variables",
    "Dark and light theme support with custom color overrides",
    "Window manager integration for Sway and Hyprland"
  ],
  "publicApiSurface": [
    "raffi - Main command to launch the application",
    "raffi -p / --print-only - Print command without executing",
    "raffi -c / --configfile - Specify custom config file",
    "raffi -r / --refresh-cache - Refresh icon cache",
    "raffi -I / --disable-icons - Disable icon display",
    "raffi -u / --ui-type - Select UI type (fuzzel or native)",
    "raffi -i / --initial-query - Set initial search query",
    "raffi -t / --theme - Select theme (dark or light)",
    "raffi --default-script-shell - Set default script interpreter",
    "~/.config/raffi/raffi.yaml - Main configuration file"
  ]
}
